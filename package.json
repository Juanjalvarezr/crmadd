{
  "name": "crm-agencia",
  "private": true,
  "react-router": {
    "routes": [
      { "path": "/login", "file": "app/routes/login.tsx" },
      { "path": "/*", "file": "app/root.tsx" }
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "npm install --legacy-peer-deps && react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "deploy": "npm run build && netlify deploy --dir=build/client --prod"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",

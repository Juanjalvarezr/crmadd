# ⚠️ IMPORTANTE: Copia este archivo como .env y reemplaza con tus credenciales
# NUNCA subas el archivo .env a GitHub (ya está en .gitignore)

# Supabase Configuration
# Ve a https://supabase.com → Tu proyecto → Settings → API
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend Configuration
# Ve a https://resend.com → Api Keys y agrega tu clave
VITE_RESEND_API_KEY=re_xxxxxxxxxxxx

# Gemini
VITE_GEMINI_API_KEY=TU_API_KEY

# Nota: Estas credenciales son para el cliente (frontend), son seguras para exponer
# No uses el SERVICE_ROLE_KEY aquí, ese es solo para el backend
